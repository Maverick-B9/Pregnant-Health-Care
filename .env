# smart-healthcare-app/.env

# --- Flask Application Settings ---
# This is critical for session security. Make it long, random, and keep it secret!
# You can generate one using Python: import secrets; secrets.token_hex(24)
SECRET_KEY='your_very_strong_random_and_secret_key_here'

# Set to 'development' for debug features, or 'production' when deployed.
FLASK_ENV='development'


# --- MySQL Database Connection Settings ---
# Replace with your actual MySQL server host (often 'localhost' for local development)
MYSQL_HOST='localhost'

# Replace with your MySQL username
MYSQL_USER='ballu'

# Replace with your MySQL password
MYSQL_PASSWORD='ballu@2003'

# The name of your MySQL database
MYSQL_DB='smarthealthcare'


# --- TensorFlow Model Path ---
# Path to your trained diagnostics model file (relative to the project root, or absolute)
TF_MODEL_PATH='app/model_path.h5'


# --- Gemini API Config ---
# Get your key from Google AI Studio
GEMINI_API_KEY='AIzaSyACIMHx98Xu6NsJt4r2V7hpB3LtG8h7K7Y'